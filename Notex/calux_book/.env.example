# Calux Book Configuration Example
# Copy this file to .env and fill in your values

# LLM Provider — Choose one or more
# ============================

# OpenAI (default)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# OR Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL= qwen2.5:7b

# OR Google Gemini (for Infographics)
GOOGLE_API_KEY=your-google-api-key-here

# Image Generation Provider
# Options: gemini, glm, zimage
IMAGE_PROVIDER=gemini
GEMINI_IMAGE_MODEL=gemini-2.0-flash-exp
GLM_API_KEY=
GLM_IMAGE_MODEL=glm-image
ZIMAGE_API_KEY=
ZIMAGE_MODEL=z-image-turbo

# Server Configuration
# ============================
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# Vector Store Configuration
# ============================
LANCEDB_PATH=./data/lancedb

# Store Configuration
# ============================
STORE_TYPE=sqlite
STORE_PATH=./data/checkpoints.db

# Agent Configuration
# ============================
MAX_SOURCES=5
MAX_CONTEXT_LENGTH=128000
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# Guest Data Management
# ============================
GUEST_EXPIRY_DAYS=30

# Feature Flags
# ============================
ALLOW_MULTIPLE_NOTES_OF_SAME_TYPE=true

# Auth / JWT
# ============================
JWT_SECRET=your-secret-key-change-me

# GitHub OAuth (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URL=

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=